{
  "name": "sdmx-rest",
  "engines": {
    "node": ">=22"
  },
  "description": "SDMX REST API client for JavaScript",
  "version": "2.20.0",
  "main": "./lib/index.js",
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('lib', { recursive: true, force: true }); require('fs').mkdirSync('lib', { recursive: true });\"",
    "build": "tsc",
    "coverage": "nyc --check-coverage --statements 100 --branches 100 --functions 100 --lines 100 --extension .ts --reporter=lcov npm test",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "mocha test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sosna/sdmx-rest4js.git"
  },
  "keywords": [
    "sdmx",
    "sdmx restful web services",
    "api"
  ],
  "author": "Xavier Sosnovsky <xso@sosna.ws>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/sosna/sdmx-rest4js/issues"
  },
  "homepage": "https://github.com/sosna/sdmx-rest4js#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^7.1.8",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.0",
    "chai": "4.3.6",
    "chai-as-promised": "7.1.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "mocha": "11.7.6",
    "nock": "13.2.8",
    "nyc": "18.0.0",
    "prettier": "^3.9.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.63.0"
  },
  "overrides": {
    "js-yaml": "4.3.0",
    "serialize-javascript": "7.0.7"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-conventional-changelog"
    }
  },
  "mocha": {
    "throw-deprecation": true,
    "require": [
      "ts-node/register"
    ],
    "inline-diffs": true,
    "timeout": 40000,
    "reporter": "spec",
    "recursive": true
  },
  "dependencies": {
    "es6-promise": "4.2.8",
    "isomorphic-fetch": "3.0.0"
  }
}
